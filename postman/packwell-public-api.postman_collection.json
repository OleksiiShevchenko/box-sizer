{
  "info": {
    "_postman_id": "7f1c8f12-9df6-4c9b-a892-7b3d6f8e7a41",
    "name": "Packwell Public API",
    "description": "Importable Postman collection for the OAuth-protected Packwell public API under /api/v1. Set the collection variables before running requests. The Create Access Token request stores the returned bearer token into the accessToken collection variable automatically.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{accessToken}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "clientId",
      "value": "",
      "type": "string"
    },
    {
      "key": "clientSecret",
      "value": "",
      "type": "string"
    },
    {
      "key": "accessToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "boxId",
      "value": "",
      "type": "string"
    },
    {
      "key": "packingPlanId",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Create Access Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('token request succeeded', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "var body = pm.response.json();",
                  "if (body && body.access_token) {",
                  "  pm.collectionVariables.set('accessToken', body.access_token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"client_id\": \"{{clientId}}\",\n  \"client_secret\": \"{{clientSecret}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/oauth/token",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "oauth",
                "token"
              ]
            },
            "description": "Exchanges the API app client credentials for a bearer token. On success, the response access_token is saved to the collection's accessToken variable."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Box",
      "item": [
        {
          "name": "List Box",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/boxes?page=1&pageSize=20",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "boxes"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "pageSize",
                  "value": "20"
                }
              ]
            },
            "description": "Returns the authenticated account's box list."
          },
          "response": []
        },
        {
          "name": "Create Box",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  var body = pm.response.json();",
                  "  if (body && body.id) {",
                  "    pm.collectionVariables.set('boxId', body.id);",
                  "  }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"measurementUnits\": \"metric\",\n  \"name\": \"Medium Carton\",\n  \"width\": 16,\n  \"height\": 12,\n  \"depth\": 10,\n  \"spacing\": 0.25,\n  \"maxWeight\": 25\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/boxes",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "boxes"
              ]
            },
            "description": "Creates a box record. `measurementUnits` is required and must be `metric` or `imperial`. On success, the returned id is saved to boxId."
          },
          "response": []
        },
        {
          "name": "Get Box",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/boxes/{{boxId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "boxes",
                "{{boxId}}"
              ]
            },
            "description": "Fetches a single box record by public id."
          },
          "response": []
        },
        {
          "name": "Update Box",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"measurementUnits\": \"metric\",\n  \"name\": \"Medium Carton - Updated\",\n  \"width\": 16,\n  \"height\": 12,\n  \"depth\": 10,\n  \"spacing\": 0.5,\n  \"maxWeight\": 30\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/boxes/{{boxId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "boxes",
                "{{boxId}}"
              ]
            },
            "description": "Updates an existing box record. `measurementUnits` is required and must be `metric` or `imperial`."
          },
          "response": []
        },
        {
          "name": "Delete Box",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/boxes/{{boxId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "boxes",
                "{{boxId}}"
              ]
            },
            "description": "Deletes a box record by public id."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Packing Plans",
      "item": [
        {
          "name": "List Packing Plans",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/packing-plans?page=1&pageSize=20",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "packing-plans"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "pageSize",
                  "value": "20"
                }
              ]
            },
            "description": "Returns the authenticated account's packing plans."
          },
          "response": []
        },
        {
          "name": "Get Packing Plan",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/packing-plans/{{packingPlanId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "packing-plans",
                "{{packingPlanId}}"
              ]
            },
            "description": "Fetches a packing plan by public id."
          },
          "response": []
        },
        {
          "name": "Update Packing Plan And Recalculate",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"unitSystem\": \"cm\",\n  \"name\": \"Demo Packing Plan\",\n  \"spacingOverride\": 0.25,\n  \"renderVisualization\": false,\n  \"items\": [\n    {\n      \"name\": \"Item A\",\n      \"quantity\": 3,\n      \"width\": 8,\n      \"height\": 4,\n      \"depth\": 6,\n      \"weight\": 250,\n      \"canStackOnTop\": true,\n      \"canBePlacedOnTop\": true,\n      \"orientation\": \"any\"\n    },\n    {\n      \"name\": \"Item B\",\n      \"quantity\": 1,\n      \"width\": 5,\n      \"height\": 5,\n      \"depth\": 5,\n      \"weight\": 120,\n      \"canStackOnTop\": false,\n      \"canBePlacedOnTop\": true,\n      \"orientation\": \"vertical\"\n    }\n  ]\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/packing-plans/{{packingPlanId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "packing-plans",
                "{{packingPlanId}}"
              ]
            },
            "description": "Updates an existing packing plan and recalculates its packing result. Use `quantity` to represent multiple identical units in one item entry. `unitSystem` is required."
          },
          "response": []
        },
        {
          "name": "Calculate Packing Plan",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"unitSystem\": \"cm\",\n  \"spacingOverride\": 0.25,\n  \"includeIdealBox\": true,\n  \"renderVisualization\": false,\n  \"items\": [\n    {\n      \"name\": \"Item A\",\n      \"quantity\": 3,\n      \"width\": 8,\n      \"height\": 4,\n      \"depth\": 6,\n      \"weight\": 250,\n      \"canStackOnTop\": true,\n      \"canBePlacedOnTop\": true,\n      \"orientation\": \"any\"\n    },\n    {\n      \"name\": \"Item B\",\n      \"quantity\": 2,\n      \"width\": 5,\n      \"height\": 5,\n      \"depth\": 5,\n      \"weight\": 120,\n      \"canStackOnTop\": false,\n      \"canBePlacedOnTop\": true,\n      \"orientation\": \"horizontal\"\n    }\n  ]\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/packing-plans/calculate",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "packing-plans",
                "calculate"
              ]
            },
            "description": "Creates a packing plan record, saves the submitted items, and calculates the best box. The response includes the created packing plan id. Use `quantity` to represent multiple identical units in one item entry. `unitSystem` is required."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Utilities",
      "item": [
        {
          "name": "Get OpenAPI Document",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/openapi.json",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "openapi.json"
              ]
            },
            "description": "Returns the OpenAPI document for this public API."
          },
          "response": []
        }
      ]
    }
  ]
}
