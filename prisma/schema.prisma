generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  password      String?
  image         String?
  unitSystem    String    @default("cm")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
  boxes        Box[]
  packingPlans PackingPlan[]
  subscription Subscription?
  calculationUsage CalculationUsage[]
  emailNotifications EmailNotification[]
  apiApps  ApiApp[]
  apiTokens ApiToken[]
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

model Box {
  id        String   @id @default(cuid())
  publicId  String   @unique @default(uuid())
  userId    String
  name      String
  width     Float
  height    Float
  depth     Float
  spacing   Float    @default(0)
  maxWeight Float?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  packingPlans PackingPlan[]

  @@index([userId])
  @@index([publicId])
}

model PackingPlan {
  id                String         @id @default(cuid())
  publicId          String         @unique @default(uuid())
  userId            String
  name              String
  spacingOverride   Float?
  boxId             String?
  dimensionalWeight Float?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  user  User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  box   Box?           @relation(fields: [boxId], references: [id], onDelete: SetNull)
  items PackingPlanItem[]

  @@index([userId])
  @@index([publicId])
}

model PackingPlanItem {
  id               String      @id @default(cuid())
  publicId         String      @unique @default(uuid())
  packingPlanId    String
  name             String
  quantity         Int         @default(1)
  width            Float
  height           Float
  depth            Float
  weight           Float?
  canStackOnTop    Boolean     @default(true)
  canBePlacedOnTop Boolean     @default(true)
  orientation      String      @default("any")

  packingPlan PackingPlan @relation(fields: [packingPlanId], references: [id], onDelete: Cascade)

  @@index([packingPlanId])
  @@index([publicId])
}

model ApiApp {
  id               String     @id @default(cuid())
  publicId         String     @unique @default(uuid())
  userId           String
  name             String
  clientId         String     @unique
  clientSecretHash String
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  user   User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokens ApiToken[]

  @@index([userId])
  @@index([clientId])
}

model ApiToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  appId     String
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  app  ApiApp @relation(fields: [appId], references: [id], onDelete: Cascade)
  user User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tokenHash])
  @@index([appId])
}

model Subscription {
  id                   String    @id @default(cuid())
  userId               String    @unique
  stripeCustomerId     String    @unique
  stripeSubscriptionId String?   @unique
  stripePriceId        String?
  tier                 String    @default("starter")
  billingInterval      String?
  status               String    @default("active")
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean   @default(false)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([stripeCustomerId])
  @@index([stripeSubscriptionId])
}

model CalculationUsage {
  id        String   @id @default(cuid())
  userId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model EmailNotification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  dedupeKey String   @unique
  status    String   @default("pending")
  subject   String
  createdAt DateTime @default(now())
  sentAt    DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
}
